<Window x:Class="MajaFaktura.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MajaFaktura"
        Title="MajaFaktura" Height="920" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5"
        Icon="Assets/company_logo_cropped.png">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentGreen" Color="#9BBB59"/>
        <SolidColorBrush x:Key="NavyBlue" Color="#17365D"/>
        <SolidColorBrush x:Key="LightBg" Color="#F0F2F5"/>
        <SolidColorBrush x:Key="CardBg" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderLight" Color="#D0D5DD"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1A1A2E"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6B7280"/>

        <!-- Section Card Style -->
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section Title -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource NavyBlue}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Field Label -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="FormTextBox" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentGreen}"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentGreen}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DatePicker Style -->
        <Style TargetType="DatePicker">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
        </Style>

        <!-- Action Button -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource AccentGreen}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#8BAA4E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#7A9944"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource NavyBlue}"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}"
                                BorderBrush="#D1D5DB" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F9FAFB"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentGreen}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small Button -->
        <Style x:Key="SmallButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Readonly TextBox (for summary) -->
        <Style x:Key="ReadOnlyField" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <!-- Column header in items list -->
        <Style x:Key="ColumnHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <!-- Item TextBox -->
        <Style x:Key="ItemTextBox" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentGreen}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Tab style -->
        <Style TargetType="TabItem">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource NavyBlue}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Toolbar -->
        <Border Grid.Row="0" Background="White" Padding="20,12"
                BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.05" Color="Black"/>
            </Border.Effect>
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="Assets/company_logo_cropped.png" Height="48" Margin="0,0,12,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="|" FontFamily="Segoe UI" FontSize="20" Foreground="#D0D5DD"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="Fakturaskapare" FontFamily="Segoe UI" FontSize="13"
                               Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Ny" Style="{StaticResource SecondaryButton}" Click="New_Click" Margin="0,0,8,0"/>
                    <Button Content="Öppna" Style="{StaticResource SecondaryButton}" Click="Open_Click" Margin="0,0,8,0"/>
                    <Button Content="Spara" Style="{StaticResource SecondaryButton}" Click="Save_Click" Margin="0,0,8,0"/>
                    <Button Content="Skriv ut" Style="{StaticResource SecondaryButton}" Click="Print_Click" Margin="0,0,8,0"/>
                    <Button Content="Spara som PDF" Style="{StaticResource ActionButton}" Click="SavePdf_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab Content -->
        <TabControl Grid.Row="1" Margin="20,16,20,20" Padding="0" BorderThickness="0"
                    Background="Transparent">

            <!-- Edit Tab -->
            <TabItem Header="Redigera">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,0,0">
                    <StackPanel MaxWidth="760">

                        <!-- Invoice Info Section -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="Fakturainformation" Style="{StaticResource SectionTitle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Fakturanummer" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding InvoiceNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Fakturadatum" Style="{StaticResource FieldLabel}"/>
                                        <DatePicker SelectedDate="{Binding InvoiceDate}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Förfallodatum" Style="{StaticResource FieldLabel}"/>
                                        <DatePicker SelectedDate="{Binding DueDate}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Customer Details Section -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="Kunduppgifter" Style="{StaticResource SectionTitle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Namn" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Personnummer" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding CustomerPersonalNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock Text="Adress" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding CustomerAddress, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                                </StackPanel>
                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock Text="Postnummer / Ort" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding CustomerPostalCity, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Reference & Terms Section -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="Referens och villkor" Style="{StaticResource SectionTitle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Referens" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding Reference, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Dröjsmålsränta (%)" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding LateInterestRate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Line Items Section -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="Tjänster" Style="{StaticResource SectionTitle}"/>

                                <!-- Column Headers -->
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Tjänst" Style="{StaticResource ColumnHeader}"/>
                                    <TextBlock Grid.Column="1" Text="Pris exkl. moms" Style="{StaticResource ColumnHeader}"/>
                                    <TextBlock Grid.Column="2" Text="Timmar" Style="{StaticResource ColumnHeader}"/>
                                    <TextBlock Grid.Column="3" Text="Moms %" Style="{StaticResource ColumnHeader}"/>
                                </Grid>

                                <!-- Item Rows -->
                                <ItemsControl ItemsSource="{Binding Items}" x:Name="ItemsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3*"/>
                                                    <ColumnDefinition Width="1.5*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="36"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Text="{Binding Service, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ItemTextBox}"/>
                                                <TextBox Grid.Column="1" Text="{Binding PriceExclVat, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ItemTextBox}"/>
                                                <TextBox Grid.Column="2" Text="{Binding Hours, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ItemTextBox}"/>
                                                <TextBox Grid.Column="3" Text="{Binding VatRate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ItemTextBox}"/>
                                                <Button Grid.Column="4" Content="X" Click="RemoveItem_Click" Tag="{Binding}"
                                                        Width="28" Height="28" FontSize="11" Cursor="Hand"
                                                        Background="#FEE2E2" Foreground="#DC2626" BorderThickness="0"
                                                        VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4"
                                                                    Width="28" Height="28">
                                                                <TextBlock Text="X" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                           FontSize="11" FontWeight="Bold" Foreground="{TemplateBinding Foreground}"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#FECACA"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button Content="+ Lägg till rad" Click="AddItem_Click" Style="{StaticResource SmallButton}"
                                        HorizontalAlignment="Left" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Deductions Section -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="Avdrag" Style="{StaticResource SectionTitle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="RUT-avdrag (kr)" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding RutDeduction, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Summary Section (Readonly) -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="Summering" Style="{StaticResource SectionTitle}"/>
                                <Border Background="#F8FBF4" CornerRadius="6" Padding="16,12" BorderBrush="#D4E4B8" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="12"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Summa exkl. moms" FontFamily="Segoe UI" FontSize="13"
                                                   Foreground="{StaticResource TextSecondary}" Margin="0,2"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SubtotalExclVat, StringFormat=N2}" FontFamily="Segoe UI" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Right" Margin="0,2"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="RUT-avdrag" FontFamily="Segoe UI" FontSize="13"
                                                   Foreground="#DC2626" Margin="0,2"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding RutDeduction, StringFormat=- {0:N2}}" FontFamily="Segoe UI" FontSize="13"
                                                   Foreground="#DC2626" HorizontalAlignment="Right" Margin="0,2"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Netto exkl. moms" FontFamily="Segoe UI" FontSize="13"
                                                   Foreground="{StaticResource TextSecondary}" Margin="0,2"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding NetAfterDeduction, StringFormat=N2}" FontFamily="Segoe UI" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Right" Margin="0,2"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" FontFamily="Segoe UI" FontSize="13"
                                                   Foreground="{StaticResource TextSecondary}" Margin="0,2">
                                            <Run Text="Moms ("/>
                                            <Run Text="{Binding VatDisplayRate, Mode=OneWay}"/>
                                            <Run Text="%)"/>
                                        </TextBlock>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding TotalVatAmount, StringFormat=N2}" FontFamily="Segoe UI" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Right" Margin="0,2"/>

                                        <Border Grid.Row="4" Grid.ColumnSpan="2" BorderBrush="#9BBB59" BorderThickness="0,0,0,2" Margin="0,4"/>

                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="ATT BETALA" FontFamily="Segoe UI" FontSize="16"
                                                   FontWeight="Bold" Foreground="{StaticResource NavyBlue}" Margin="0,2"/>
                                        <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding GrandTotal, StringFormat=N0}" FontFamily="Segoe UI" FontSize="16"
                                                       FontWeight="Bold" Foreground="{StaticResource NavyBlue}" Margin="0,2"/>
                                            <TextBlock Text=" kr" FontFamily="Segoe UI" FontSize="16"
                                                       FontWeight="Bold" Foreground="{StaticResource NavyBlue}" Margin="0,2"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Company Info Section (Collapsible) -->
                        <Border Style="{StaticResource SectionCard}">
                            <Expander Header="Företagsuppgifter" IsExpanded="False" FontFamily="Segoe UI" FontSize="15"
                                      FontWeight="SemiBold" Foreground="{StaticResource NavyBlue}">
                                <StackPanel Margin="0,12,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Företagsnamn" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Telefon" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding CompanyPhone, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                                        </StackPanel>
                                    </Grid>
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Adress" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding CompanyAddress, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="E-post" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding CompanyEmail, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                                        </StackPanel>
                                    </Grid>
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Postnummer / Ort" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding CompanyPostalCity, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Momsreg.nr" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding CompanyVatNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                                        </StackPanel>
                                    </Grid>
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Banknamn" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding CompanyBankName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Bankgiro / Kontonummer" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding CompanyBankInfo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Expander>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Preview Tab -->
            <TabItem Header="Förhandsgranska">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                              Background="#E5E7EB" Padding="20">
                    <Border Background="White" HorizontalAlignment="Center" Margin="0,20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.15" Color="Black"/>
                        </Border.Effect>
                        <local:InvoicePrintView x:Name="PreviewControl"/>
                    </Border>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
